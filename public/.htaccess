# ======================================
# CONFIGURAÇÕES GERAIS
# ======================================

Options -MultiViews
DirectoryIndex index.html index.php

RewriteEngine On

# ======================================
# REDIRECIONAMENTOS LEGADOS (MANTÉM COMPATIBILIDADE)
# ======================================

RewriteRule ^php/api/(.*)$ /api/$1 [R=301,L]
RewriteRule ^php/cms/(.*)$ /cms/$1 [R=301,L]

# Força o index.php se acessar a pasta /cms/ pura (evita 403)
RewriteRule ^cms/$ /cms/index.php [L]
RewriteRule ^cms$ /cms/index.php [L]

# ======================================
# FORÇAR HTTPS (SSL) E SEGURANÇA HSTS
# ======================================
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} =http [OR]
RewriteCond %{SERVER_PORT} 80
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# HSTS: Exige HTTPS sempre (1 ano de validade, útil para SEO)
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ======================================
# REDIRECT WWW → SEM WWW (CANONICAL)
# ======================================

# m2flex www → sem www
RewriteCond %{HTTP_HOST} ^www\.m2flex\.com\.br$ [NC]
RewriteRule ^ https://m2flex.com.br%{REQUEST_URI} [R=301,L]

# m2midias www → sem www
RewriteCond %{HTTP_HOST} ^www\.m2midias\.com\.br$ [NC]
RewriteRule ^ https://m2midias.com.br%{REQUEST_URI} [R=301,L]

# ======================================
# DOMINIOS ACEITOS
# ======================================

RewriteCond %{HTTP_HOST} !^(m2flex\.com\.br|www\.m2flex\.com\.br|m2midias\.com\.br|www\.m2midias\.com\.br)$ [NC]
RewriteRule ^ - [F,L]

# ======================================
# NUNCA CACHEAR index.html
# ======================================

<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# ======================================
# LITESPEED CACHE OFF
# ======================================

<IfModule LiteSpeed>
  CacheLookup off
</IfModule>

# ======================================
# CACHE DE ALTA PERFORMANCE (LCP/SEO)
# ======================================

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  
  # Imagens (1 ano)
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Vídeos e Áudio (1 ano)
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
  
  # Scripts & Estilos (1 ano - Seguro com Hash)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  
  # Fontes (1 ano)
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Força Cache-Control para assets estáticos
  <FilesMatch "\.(jpg|jpeg|png|gif|swf|svg|js|css|mp4|webm|woff|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>


# ======================================
# PÁGINA DE ERRO (STATUS 404 REAL)
# ======================================
ErrorDocument 404 /404.html

# ======================================
# REACT ROUTER & SSG → index.html (OTIMIZADO)
# ======================================

# 1. Se o arquivo ou diretório existir Fisicamente (assets, docs, etc), para aqui
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. Fallback especial para BLOG (Permite posts dinâmicos novos sem rebuild)
RewriteRule ^blog(/.*)?$ index.html [L]

# 3. Tenta encontrar arquivos gerados pelo react-snap (SSG)
# Ex: /quem-somos servindo /quem-somos/index.html
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]

# Ex: /contato servindo /contato.html
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.*)$ $1.html [L]

# 4. Fallback final para a Home
RewriteRule ^$ index.html [L]

# SE CHEGAR AQUI E NÃO FOR NADA DISSO, O APACHE DARÁ 404 AUTOMATICO (REQUISITO SEO)